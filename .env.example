# Pooled Neon connection string for app/runtime queries.
# Neon pooled hosts usually include "-pooler" and sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Direct Neon connection string for Prisma introspection/admin tasks.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

NEXT_PUBLIC_APP_NAME="Wallet Performance Analytics"
